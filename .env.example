# SeeCAD reads OPENAI_API_KEY from the environment. Never commit a real key.
OPENAI_API_KEY=
SEECAD_MODEL=gpt-5.6
SEECAD_REASONING_MODE=pro
SEECAD_REASONING_EFFORT=max
SEECAD_OPENAI_TIMEOUT_SECONDS=480
SEECAD_DATA_DIR=.seecad
SEECAD_OPENSCAD_MODE=docker
SEECAD_OPENSCAD_IMAGE=seecad-openscad:local
SEECAD_OPENSCAD_TIMEOUT_SECONDS=90
SEECAD_ALLOWED_ORIGINS=http://localhost:5173
